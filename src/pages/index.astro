<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('home-contact-form');
        const toast = document.getElementById('home-toast');
        const btn = document.getElementById('home-submit-btn');

        if (form) {
            form.addEventListener('submit', (e) => {
                e.preventDefault(); 

                const myForm = e.target;
                const formData = new FormData(myForm);

                if (!formData.has('form-name')) {
                    formData.append('form-name', myForm.getAttribute('name'));
                }

                // Wyciąganie imienia dla Zapiera
                const pelneImie = formData.get('imie').toString().trim();
                let samoImie = pelneImie.split(' ')[0];
                samoImie = samoImie.charAt(0).toUpperCase() + samoImie.slice(1).toLowerCase();
                formData.append('samo_imie', samoImie);

                let originalBtnText = "Wyślij zapytanie";
                if(btn) {
                    originalBtnText = btn.innerText;
                    btn.innerText = "Wysyłanie...";
                    btn.style.opacity = "0.7";
                    btn.disabled = true;
                }

                fetch('/', {
                    method: 'POST',
                    headers: { "Content-Type": "application/x-www-form-urlencoded" },
                    body: new URLSearchParams(formData).toString()
                })
                .then(() => {
                    myForm.reset();
                    if(toast) {
                        toast.classList.remove('translate-y-32', 'opacity-0', 'pointer-events-none');
                        setTimeout(() => {
                            toast.classList.add('translate-y-32', 'opacity-0', 'pointer-events-none');
                        }, 5000);
                    }
                    if(btn) {
                        btn.innerText = "Wysłano pomyślnie!";
                        btn.style.background = "#10B981";
                        setTimeout(() => {
                            btn.innerText = originalBtnText;
                            btn.style.background = "";
                            btn.style.opacity = "1";
                            btn.disabled = false;
                        }, 3000);
                    }
                })
                .catch((error) => {
                    alert('Wystąpił błąd połączenia.');
                    if(btn) {
                        btn.innerText = originalBtnText;
                        btn.style.opacity = "1";
                        btn.disabled = false;
                    }
                });
            });
        }
    });
</script>