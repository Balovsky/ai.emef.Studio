    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const container = document.getElementById('interactive-container');
            const btns = document.querySelectorAll('.tab-btn');
            const contents = document.querySelectorAll('.tab-content');
            
            let currentTabIndex = 0;
            let autoplayInterval;

            const activeClasses = ['bg-white', 'shadow-md', 'text-slate-900'];
            const inactiveClasses = ['text-gray-500', 'hover:text-slate-900', 'bg-transparent', 'shadow-none'];

            // 1. ZARZĄDZANIE ZAKŁADKAMI
            function switchTab(index) {
                // Ukryj wszystkie
                contents.forEach(c => {
                    c.classList.add('hidden');
                    c.classList.remove('block');
                });
                btns.forEach(b => {
                    b.classList.remove(...activeClasses);
                    b.classList.add(...inactiveClasses);
                });

                // Pokaż wybrany
                contents[index].classList.remove('hidden');
                contents[index].classList.add('block');
                btns[index].classList.remove(...inactiveClasses);
                btns[index].classList.add(...activeClasses);
                
                currentTabIndex = index;
            }

            // Podpięcie kliknięcia pod przyciski
            btns.forEach((btn, index) => {
                btn.addEventListener('click', () => {
                    switchTab(index);
                    stopAutoplay(); // Jeśli kliknął ręcznie, zatrzymaj automat
                });
            });

            // 2. AUTOPLAY LOGIC
            function startAutoplay() {
                autoplayInterval = setInterval(() => {
                    let nextIndex = (currentTabIndex + 1) % btns.length;
                    switchTab(nextIndex);
                }, 8000); // Zmiana co 8 sekund
            }

            function stopAutoplay() {
                clearInterval(autoplayInterval);
            }

            // Rozpocznij automat
            startAutoplay();

            // Zatrzymaj, gdy klient najedzie lub dotknie interaktywnej sekcji
            if(container) {
                container.addEventListener('mouseenter', stopAutoplay);
                container.addEventListener('touchstart', stopAutoplay, {passive: true});
            }

            // 3. LOGIKA: KASKADA AI (Tab 1)
            const mainImg = document.getElementById('ai-main-img');
            const mainTitle = document.getElementById('ai-main-title');
            const thumbs = document.querySelectorAll('.ai-thumb');

            thumbs.forEach(thumb => {
                thumb.addEventListener('mouseenter', function() {
                    // Reset borders
                    thumbs.forEach(t => {
                        t.classList.remove('border-blue-500');
                        t.classList.add('border-transparent');
                        const overlay = t.querySelector('.absolute');
                        if(overlay) overlay.classList.remove('hidden');
                    });

                    // Set active border
                    this.classList.remove('border-transparent');
                    this.classList.add('border-blue-500');
                    const overlay = this.querySelector('.absolute');
                    if(overlay) overlay.classList.add('hidden');

                    // Change main image and text
                    if(mainImg) mainImg.src = this.getAttribute('data-src');
                    if(mainTitle) mainTitle.innerText = this.getAttribute('data-title');
                });
            });

            // 4. LOGIKA: KALKULATOR (Tab 3)
            // 4. LOGIKA: KALKULATOR (Tab 3)
            const inputProducts = document.getElementById('calc-products');
            const inputPhotos = document.getElementById('calc-photos');
            const wrapperPhotos = document.getElementById('calc-photos-wrapper'); // Nasz kontener z suwakiem ujęć
            
            const valProducts = document.getElementById('calc-products-val');
            const valPhotos = document.getElementById('calc-photos-val');
            const textTrad = document.getElementById('calc-trad-cost');
            const textKM = document.getElementById('calc-km-cost');
            const textSavings = document.getElementById('calc-savings');
            const infoText = document.getElementById('calc-info-text');
            const calcTypes = document.querySelectorAll('.calc-type-btn');

            let currentCalcType = 'packshot';

            const rates = {
                'packshot': { 
                    tradBase: 0, tradPic: 30, kmBase: 0, kmPic: 20,
                    info: "* Oszczędzasz na wynajmie studia na godziny oraz logistyce."
                },
                'ai': { 
                    tradBase: 0, tradPic: 40, kmBase: 0, kmPic: 30,
                    info: "* W tradycyjnej agencji płacisz za studio, modelkę z agencji i wizażystkę. U nas generuje to sztuczna inteligencja."
                },
                'real': { 
                    tradBase: 0, tradPic: 80, kmBase: 0, kmPic: 50,
                    info: "* Oszczędzasz na ukrytych prowizjach agencji modelek. Mamy stałe, sprawdzone osoby."
                },
                '360': { 
                    tradBase: 0, tradPic: 120, kmBase: 0, kmPic: 60,
                    info: "* W wideo 360° wykonujemy 1 pełny obrót na produkt. Zoptymalizowaliśmy ten proces do maksimum."
                }
            };

            function calculateCost() {
                if(!inputProducts || !inputPhotos) return;

                const p = parseInt(inputProducts.value);
                let ph = parseInt(inputPhotos.value);
                const rate = rates[currentCalcType];

                // Ukrywamy suwak "Ujęć" jeśli wybrano Wideo 360 i wymuszamy 1 ujęcie w obliczeniach
                if (currentCalcType === '360') {
                    if (wrapperPhotos) {
                        wrapperPhotos.style.opacity = '0';
                        wrapperPhotos.style.height = '0px';
                        wrapperPhotos.style.pointerEvents = 'none';
                    }
                    ph = 1; // 360 to zawsze 1 rotacja
                } else {
                    if (wrapperPhotos) {
                        wrapperPhotos.style.opacity = '1';
                        wrapperPhotos.style.height = '60px'; // przywraca standardową wysokość
                        wrapperPhotos.style.pointerEvents = 'auto';
                    }
                }

                if(valProducts) valProducts.innerText = p.toString();
                if(valPhotos) valPhotos.innerText = ph.toString();
                if(infoText) infoText.innerText = rate.info;

                // Obliczenia
                const tradCost = rate.tradBase + (p * ph * rate.tradPic);
                const kmCost = rate.kmBase + (p * ph * rate.kmPic);
                const savings = tradCost - kmCost;

                // Aktualizacja UI
                if(textTrad) textTrad.innerText = tradCost.toLocaleString('pl-PL') + ' zł';
                if(textKM) textKM.innerText = kmCost.toLocaleString('pl-PL') + ' zł';
                if(textSavings) textSavings.innerText = savings.toLocaleString('pl-PL') + ' zł';
            }

            // Obsługa kliknięć w przyciski typów
            calcTypes.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    calcTypes.forEach(b => {
                        b.classList.remove('bg-blue-600', 'text-white');
                        b.classList.add('bg-transparent', 'text-gray-400');
                    });
                    
                    const target = e.currentTarget;
                    // @ts-ignore
                    target.classList.remove('bg-transparent', 'text-gray-400');
                    // @ts-ignore
                    target.classList.add('bg-blue-600', 'text-white');
                    
                    // @ts-ignore
                    currentCalcType = target.getAttribute('data-type');
                    calculateCost();
                });
            });

            if(inputProducts && inputPhotos) {
                inputProducts.addEventListener('input', calculateCost);
                inputPhotos.addEventListener('input', calculateCost);
                calculateCost(); 
            }

            // Podpięcie zdarzeń
            if(inputProducts && inputPhotos) {
                inputProducts.addEventListener('input', calculateCost);
                inputPhotos.addEventListener('input', calculateCost);
                calculateCost(); // Initial calc
            }
        });
    </script>

