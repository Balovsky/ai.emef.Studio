---
// Plik: src/pages/blog.astro
import MainLayout from '../layouts/MainLayout.astro';

const blogPosts = [
    {
        id: 'sklep-stolarz',
        date: '10 Marca 2026',
        category: 'Realizacja',
        readTime: '3 min czytania',
        title: 'Od zera do prosperującego e-commerce dla lokalnego stolarza',
        excerpt: 'Zobacz, jak przenieśliśmy tradycyjny biznes stolarski do internetu, budując nowoczesny sklep i wykonując pełną sesję zdjęciową mebli.',
        coverImage: 'https://images.unsplash.com/photo-1610555356070-d0efb6505f81?q=80&w=1000&auto=format&fit=crop',
    },
    {
        id: '3-sekundy',
        date: '28 Lutego 2026',
        category: 'Wiedza',
        readTime: '4 min czytania',
        title: 'Dlaczego 3 pierwsze sekundy decydują o tym, czy klient u Ciebie kupi?',
        excerpt: 'Klienci kupują oczami. Zobacz, jak jakość zdjęć produktowych wpływa na porzucane koszyki i podejmij mądrą decyzję dla swojego biznesu.',
        coverImage: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?q=80&w=1000&auto=format&fit=crop',
    },
    {
        id: 'identyfikacja-kalendarz',
        date: '15 Stycznia 2026',
        category: 'Realizacja',
        readTime: '2 min czytania',
        title: 'Kompleksowa identyfikacja wizualna i kalendarze firmowe',
        excerpt: 'Projekt logo, wizytówek, teczek ofertowych i spersonalizowanego kalendarza dla firmy z branży logistycznej.',
        coverImage: 'https://images.unsplash.com/photo-1629429408209-1f912961dbd8?q=80&w=1000&auto=format&fit=crop',
    }
];
---

<MainLayout title="Blog & Realizacje | K&M Studio">

    <header class="pt-32 pb-20 px-4 text-center bg-slate-50 border-b border-gray-100">
        <span class="text-blue-600 font-bold tracking-widest text-xs uppercase mb-4 block" data-aos="fade-down">Blog & Case Studies</span>
        <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-6 tracking-tight" data-aos="fade-up">
            Baza Wiedzy i Realizacje
        </h1>
        <p class="text-lg md:text-xl text-gray-500 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
            Czytaj nasze poradniki e-commerce i zobacz, jak w praktyce rozwiązujemy problemy naszych klientów.
        </p>
    </header>

    <section class="py-24 bg-white px-4">
        <div class="max-w-7xl mx-auto grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {blogPosts.map((post, index) => (
                <a href={`/blog/${post.id}`} class="group bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col block" data-aos="fade-up" data-aos-delay={index * 100}>
                    <div class="relative w-full aspect-[4/3] overflow-hidden bg-gray-100">
                        <img src={post.coverImage} class="absolute inset-0 w-full h-full object-cover transition duration-700 group-hover:scale-105" alt={post.title} />
                        <div class="absolute top-4 left-4">
                            <span class={`text-xs font-bold px-3 py-1.5 rounded-lg shadow-sm ${post.category === 'Wiedza' ? 'bg-purple-100 text-purple-700' : 'bg-blue-100 text-blue-700'}`}>
                                {post.category}
                            </span>
                        </div>
                    </div>
                    <div class="p-6 md:p-8 flex flex-col flex-grow">
                        <div class="flex justify-between items-center text-xs text-gray-400 font-medium mb-3">
                            <span>{post.date}</span>
                            <span>{post.readTime}</span>
                        </div>
                        <h2 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-blue-600 transition duration-300 line-clamp-2">
                            {post.title}
                        </h2>
                        <p class="text-sm text-gray-500 mb-6 line-clamp-3 flex-grow">
                            {post.excerpt}
                        </p>
                        <div class="mt-auto text-blue-600 text-sm font-bold flex items-center gap-2 group-hover:gap-3 transition-all">
                            Czytaj artykuł <span class="text-lg">→</span>
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </section>

</MainLayout>