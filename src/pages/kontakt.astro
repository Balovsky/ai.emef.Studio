---
// Plik: src/pages/kontakt.astro
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Kontakt & Wycena | K&M Studio">

    <header class="pt-32 pb-16 bg-white text-center px-4">
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6" data-aos="fade-up">
            Rozpocznijmy współpracę.
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed" data-aos="fade-up" data-aos-delay="100">
            Masz świetne produkty? My mamy technologię i czas, by je sprzedać. <br/>
            Napisz do nas, zadzwoń, albo po prostu wyślij zapytanie.
        </p>
        <div class="mt-8 inline-flex items-center justify-center gap-3 bg-blue-50 border border-blue-100 text-blue-800 px-6 py-3 rounded-full text-sm md:text-base font-bold shadow-sm" data-aos="fade-up" data-aos-delay="200">
            <span class="text-xl">🎁</span>
            <span>Chcesz sprawdzić jakość? Pierwsza sesja z 1 produktem jest darmowa!</span>
        </div>
    </header>

    <section class="pb-24 px-4">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-24 items-start">
            
            <div data-aos="fade-right">
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
                    <div class="bg-blue-50 p-6 rounded-3xl border border-blue-100 hover:border-blue-300 transition group text-center flex flex-col justify-center shadow-sm">
                        <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-sm text-blue-600 mb-4 text-2xl mx-auto group-hover:scale-110 transition">👨‍💻</div>
                        <h3 class="font-bold text-gray-900 text-lg">Mariusz</h3>
                        <p class="text-[10px] uppercase font-bold text-blue-600 tracking-wider mb-4">Właściciel / Tech & Foto</p>
                        <a href="tel:+48789193827" class="text-lg md:text-xl font-black text-slate-800 hover:text-blue-600 transition block">+48 789 193 827</a>
                    </div>
                    
                    <div class="bg-gray-50 p-6 rounded-3xl border border-gray-200 hover:border-gray-300 transition group text-center flex flex-col justify-center shadow-sm">
                        <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-sm text-gray-600 mb-4 text-2xl mx-auto group-hover:scale-110 transition">✉️</div>
                        <h3 class="font-bold text-gray-900 text-lg">Napisz do nas</h3>
                        <p class="text-[10px] uppercase font-bold text-gray-500 tracking-wider mb-4">Szybka wycena</p>
                        <a href="mailto:kontakt@studio.ai" class="text-base md:text-lg font-bold text-slate-800 hover:text-blue-600 transition block">kontakt@studio.ai</a>
                    </div>
                </div>

                <div class="bg-slate-900 text-white p-8 md:p-10 rounded-3xl relative overflow-hidden shadow-2xl border border-slate-800">
                    <div class="absolute top-0 right-0 w-40 h-40 bg-green-500 rounded-full blur-[80px] opacity-20 -mr-10 -mt-10 pointer-events-none"></div>
                    
                    <h3 class="text-2xl font-bold mb-6 flex items-center gap-3 relative z-10">
                        <span class="text-3xl">📦</span>
                        Jak przekazać produkty?
                    </h3>
                    
                    <div class="space-y-5 text-gray-300 text-sm leading-relaxed relative z-10">
                        <p>Nie musisz nigdzie jeździć. Po wstępnej wycenie i ustaleniu szczegółów, podamy Ci dokładny adres naszego studia. Cały proces możemy załatwić na dwa sposoby:</p>
                        
                        <ul class="space-y-4 mt-2">
                            <li class="flex items-start gap-3 bg-white/5 p-4 rounded-xl border border-white/10">
                                <span class="text-green-400 font-bold text-lg mt-0.5">1.</span> 
                                <div>
                                    <strong class="text-white block mb-1">Wysyłka kurierem z całej Polski</strong>
                                    Pakujesz towar w karton i nadajesz paczkę. Po udanej sesji odsyłamy wszystko bezpiecznie z powrotem.
                                </div>
                            </li>
                            <li class="flex items-start gap-3 bg-white/5 p-4 rounded-xl border border-white/10">
                                <span class="text-green-400 font-bold text-lg mt-0.5">2.</span> 
                                <div>
                                    <strong class="text-white block mb-1">Odbiór lokalny</strong>
                                    Działasz w okolicach <strong>Kalwarii Zebrzydowskiej lub Wadowic?</strong> Umówimy się na wygodny odbiór u Ciebie w firmie lub u nas na miejscu.
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="bg-white p-8 md:p-10 rounded-3xl shadow-2xl border border-gray-100 relative min-h-[500px]" data-aos="fade-left">
                <h3 class="text-2xl font-bold mb-2">Darmowa Wycena</h3>
                <p class="text-gray-500 text-sm mb-8">Wypełnij formularz, a my wrócimy do Ciebie z propozycją w 24 godziny.</p>
                
                <form id="contact-form" name="kontakt-strona" method="POST" data-netlify="true" enctype="multipart/form-data" class="space-y-5">
                    <input type="hidden" name="form-name" value="kontakt-strona" />
                    
                    <div class="grid md:grid-cols-2 gap-5">
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">Imię i Nazwisko</label>
                            <input type="text" name="imie" placeholder="Jan Kowalski" class="w-full bg-gray-50 border border-gray-200 rounded-xl p-3 focus:outline-none focus:border-blue-500 transition" required />
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">Firma (Opcjonalnie)</label>
                            <input type="text" name="firma" placeholder="Nazwa Twojej firmy" class="w-full bg-gray-50 border border-gray-200 rounded-xl p-3 focus:outline-none focus:border-blue-500 transition" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Adres Email</label>
                        <input type="email" name="email" placeholder="jan@firma.pl" class="w-full bg-gray-50 border border-gray-200 rounded-xl p-3 focus:outline-none focus:border-blue-500 transition" required />
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Jakiej usługi potrzebujesz?</label>
                        <div class="relative">
                            <select name="temat" class="w-full bg-gray-50 border border-gray-200 rounded-xl p-3 appearance-none focus:outline-none focus:border-blue-500 transition text-gray-700 font-medium" required>
                                <option value="" disabled selected>-- Wybierz z listy --</option>
                                <option value="Same Zdjęcia">Same Zdjęcia (Packshoty / Tła AI)</option>
                                <option value="Święty Spokój">Święty Spokój (Zdjęcia + Wgranie na sklep)</option>
                                <option value="Stała Współpraca">Stała współpraca / Abonament</option>
                                <option value="Grafika i Druk">Grafika, Druk, Social Media</option>
                                <option value="Inne">Inne zapytanie</option>
                            </select>
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-500">▼</div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Opisz swoje produkty</label>
                        <textarea name="wiadomosc" rows="4" placeholder="Np. Mam do sfotografowania 20 par butów i zależy mi również na wstawieniu ich na mój sklep WooCommerce..." class="w-full bg-gray-50 border border-gray-200 rounded-xl p-3 focus:outline-none focus:border-blue-500 transition" required></textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Załącznik (np. cennik lub przykładowe zdjęcie)</label>
                        <input type="file" name="zalacznik" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition cursor-pointer"/>
                        <p class="text-[10px] text-gray-400 mt-1">Max 10MB. Format: JPG, PNG, PDF.</p>
                    </div>

                    <button type="submit" id="submit-btn" class="w-full bg-blue-600 text-white font-bold py-4 rounded-xl hover:bg-blue-700 transition shadow-lg transform hover:-translate-y-1">
                        Wyślij zapytanie
                    </button>
                </form>
            </div>

        </div>
    </section>

    <div id="toast" class="fixed bottom-10 left-1/2 transform -translate-x-1/2 translate-y-32 opacity-0 z-50 max-w-[90vw] w-auto bg-white border border-green-100 shadow-2xl rounded-2xl p-4 md:p-6 flex items-center gap-4 transition-all duration-500 pointer-events-none">
        <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
        </div>
        <div>
            <h4 class="font-bold text-gray-900 text-sm md:text-base">Wiadomość wysłana!</h4>
            <p class="text-xs md:text-sm text-gray-500 mt-1">Dziękujemy. Wrócimy z wyceną w 24 godziny.</p>
        </div>
    </div>

</MainLayout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        
        const form = document.getElementById('contact-form');
        const toast = document.getElementById('toast');
        const btn = form ? form.querySelector('button[type="submit"]') : null;

        if (form) {
            form.addEventListener('submit', (e) => {
                e.preventDefault(); 

                const myForm = e.target;
                const formData = new FormData(myForm); // To automatycznie pobierze plik!

                if (!formData.has('form-name')) {
                    // @ts-ignore
                    formData.append('form-name', myForm.getAttribute('name'));
                }

                let originalBtnText = "Wyślij zapytanie";

                if(btn) {
                    originalBtnText = btn.innerText;
                    btn.innerText = "Wysyłanie...";
                    btn.style.opacity = "0.7";
                    // @ts-ignore
                    btn.disabled = true;
                }

                fetch('/', {
                    method: 'POST',
                    body: formData 
                })
                .then(() => {
                    // @ts-ignore
                    myForm.reset();
                    
                    if(toast) {
                        toast.classList.remove('translate-y-32', 'opacity-0', 'pointer-events-none');
                        setTimeout(() => {
                            toast.classList.add('translate-y-32', 'opacity-0', 'pointer-events-none');
                        }, 5000);
                    }

                    if(btn) {
                        btn.innerText = "Wysłano pomyślnie!";
                        btn.style.backgroundColor = "#10B981"; 
                        
                        setTimeout(() => {
                            btn.innerText = originalBtnText;
                            btn.style.backgroundColor = ""; 
                            btn.style.opacity = "1";
                            // @ts-ignore
                            btn.disabled = false;
                        }, 3000);
                    }
                })
                .catch((error) => {
                    console.error("Błąd formularza:", error);
                    alert('Wystąpił błąd połączenia. Spróbuj ponownie.');
                    
                    if(btn) {
                        btn.innerText = originalBtnText;
                        btn.style.opacity = "1";
                        // @ts-ignore
                        btn.disabled = false;
                    }
                });
            });
        }
    });
</script>

