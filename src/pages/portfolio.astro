---
// Plik: src/pages/portfolio.astro
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Portfolio Projekty | K&M Studio">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />

    <div class="pt-32 pb-12 bg-white text-center px-4">
        <span class="text-blue-600 font-bold tracking-widest text-xs uppercase mb-4 block" data-aos="fade-down">K&M Studio Wewnętrznie</span>
        <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-6 tracking-tight" data-aos="fade-up">
            Kompleksowe Kampanie
        </h1>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto mb-10" data-aos="fade-up" data-aos-delay="100">
            Od białego tła, przez wygenerowane AI sesje modowe, aż po materiały do druku. Zobacz całe kampanie.
        </p>

        <div class="bg-slate-100 p-1.5 md:p-2 rounded-full inline-flex mx-auto" data-aos="fade-up" data-aos-delay="200">
            <button id="btn-ecommerce" class="px-6 md:px-10 py-3 md:py-4 rounded-full text-sm md:text-base font-bold bg-white text-slate-900 shadow-lg transition-all duration-300">
                Kampanie E-commerce
            </button>
            <button id="btn-dtp" class="px-6 md:px-10 py-3 md:py-4 rounded-full text-sm md:text-base font-bold text-gray-500 hover:text-slate-900 transition-all duration-300">
                Materiały do Druku (DTP)
            </button>
        </div>
    </div>


    <div id="view-ecommerce" class="max-w-[1400px] mx-auto px-4 pb-24 space-y-8 animate-fade-in-slow">
        
         <div class="project-row relative bg-slate-50 border border-slate-200 rounded-[2rem] p-4 md:p-8 shadow-sm hover:shadow-xl transition-all duration-700 cursor-pointer group" onclick="toggleRow(this, event)">
            
            <div class="flex justify-between items-center mb-6">
                <div>
                    <span class="text-purple-600 text-xs font-bold uppercase tracking-widest bg-purple-100 px-3 py-1 rounded-full mb-2 inline-block">Kolekcja #2</span>
                    <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Kolekcja obuwia premium</h2>
                </div>
                <div class="text-gray-400 group-hover:text-purple-600 transition-colors">
                    <span class="text-sm font-bold hidden md:inline mr-2 expand-text">Kliknij wiersz, aby powiększyć</span>
                    <svg class="w-8 h-8 inline-block transform transition-transform duration-500 expand-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </div>
            </div>

            <div class="project-grid grid grid-cols-1 lg:grid-cols-4 gap-4 md:gap-6 h-[450px] lg:h-[320px] overflow-hidden transition-all duration-[800ms] ease-in-out">
                
                <div class="lg:col-span-1 grid grid-cols-2 grid-rows-2 gap-2 md:gap-4 h-full min-h-0">
                    <a href="/images/portfolio/packshot1.jpg" data-fancybox="kosmetyki" class="block rounded-xl overflow-hidden shadow-sm border border-gray-100 bg-white relative">
                        <img src="/images/portfolio/packshot1.jpg" loading="lazy" decoding="async" class="w-full h-full object-contain p-2 md:p-4 hover:scale-110 transition-transform duration-700"/>
                        <div class="absolute bottom-2 left-2 bg-black/60 text-white text-[10px] px-2 py-1 rounded backdrop-blur-sm hidden lg:block">Baza: Packshot</div>
                    </a>
                    <a href="/images/portfolio/packshot2.jpg" data-fancybox="kosmetyki" class="block rounded-xl overflow-hidden shadow-sm border border-gray-100 bg-white relative">
                        <img src="/images/portfolio/packshot2.jpg" loading="lazy" decoding="async" class="w-full h-full object-contain p-2 md:p-4 hover:scale-110 transition-transform duration-700"/>
                    </a>
                    <a href="/images/portfolio/packshot3.jpg" data-fancybox="kosmetyki" class="block rounded-xl overflow-hidden shadow-sm border border-gray-100 bg-white relative">
                        <img src="/images/portfolio/packshot3.jpg" loading="lazy" decoding="async" class="w-full h-full object-contain p-2 md:p-4 hover:scale-110 transition-transform duration-700"/>
                    </a>
                    <a href="/images/portfolio/packshot4.jpg" data-fancybox="kosmetyki" class="block rounded-xl overflow-hidden shadow-sm border border-gray-100 bg-white relative">
                        <img src="/images/portfolio/packshot4.jpg" loading="lazy" decoding="async" class="w-full h-full object-contain p-2 md:p-4 hover:scale-110 transition-transform duration-700"/>
                    </a>
                </div>

                <div class="lg:col-span-2 grid grid-cols-3 grid-rows-3 gap-2 md:gap-3 h-full min-h-0 relative">
                    
                    <a href="/images/portfolio/modowe2.jpg" data-fancybox="kosmetyki" class="col-span-2 row-span-2 block rounded-xl overflow-hidden shadow-md relative group/fashion">
                        <img src="/images/portfolio/modowe2.jpg" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover/fashion:scale-105 transition-transform duration-700"/>
                        <div class="absolute bottom-2 left-2 bg-purple-600 text-white text-[10px] font-bold px-2 py-1 rounded-md shadow-lg z-10 hidden md:block">MODELKA + AI</div>
                    </a>
                    
                    <a href="/images/portfolio/modowe1.jpg" data-fancybox="kosmetyki" class="col-span-1 row-span-1 block rounded-xl overflow-hidden shadow-sm relative group/fashion">
                        <img src="/images/portfolio/modowe1.jpg" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover/fashion:scale-105 transition-transform duration-700"/>
                    </a>

                    <a href="/images/portfolio/morze.webp" data-fancybox="kosmetyki" class="col-span-1 row-span-1 block rounded-xl overflow-hidden shadow-sm relative group/fashion">
                        <img src="/images/portfolio/morze.webp" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover/fashion:scale-105 transition-transform duration-700"/>
                    </a>

                    <a href="/images/portfolio/studio.webp" data-fancybox="kosmetyki" class="col-span-2 row-span-1 block rounded-xl overflow-hidden shadow-sm relative group/fashion">
                        <img src="/images/portfolio/studio.webp" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover/fashion:scale-105 transition-transform duration-700"/>
                    </a>

                    <a href="/images/portfolio/paryz.webp" data-fancybox="kosmetyki" class="col-span-1 row-span-1 block rounded-xl overflow-hidden shadow-sm relative group/fashion">
                        <img src="/images/portfolio/paryz.webp" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover/fashion:scale-105 transition-transform duration-700"/>
                    </a>
                </div>

                <div class="lg:col-span-1 grid grid-cols-2 lg:grid-cols-1 grid-rows-1 lg:grid-rows-2 gap-2 md:gap-4 h-full min-h-0">
                    <a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ" data-fancybox="kosmetyki" class="block rounded-xl overflow-hidden shadow-sm bg-slate-900 relative group/vid">
                        <img src="/images/portfolio/modowe1.jpg" loading="lazy" decoding="async" class="w-full h-full object-cover opacity-50 group-hover/vid:scale-110 transition-transform duration-700">
                        <div class="absolute inset-0 flex items-center justify-center">
                            <div class="w-10 h-10 md:w-14 md:h-14 bg-white/30 rounded-full flex items-center justify-center transition backdrop-blur-md">
                                <svg class="w-5 h-5 md:w-6 md:h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                            </div>
                        </div>
                        <div class="absolute top-2 left-2 bg-red-600 text-white text-[10px] font-bold px-2 py-1 rounded hidden lg:block">Video już wkrótce</div>
                    </a>
                    <a href="/images/portfolio/packshot1.jpg" data-fancybox="kosmetyki" class="block rounded-xl overflow-hidden shadow-sm bg-white border border-gray-100 relative group/360">
                        <img src="/images/portfolio/packshot1.jpg" loading="lazy" decoding="async" class="w-full h-full object-contain p-4 group-hover/360:scale-110 transition-transform duration-700">
                        <div class="absolute inset-0 flex items-center justify-center bg-black/5">
                            <div class="bg-black/80 text-white px-3 py-1.5 md:px-4 md:py-2 rounded-full font-bold text-xs md:text-sm flex items-center gap-2 backdrop-blur-sm shadow-xl">
                                Widok 360°
                            </div>
                        </div>
                        
                    </a>
                </div>
            </div>
        </div>

        <div class="project-row relative bg-slate-50 border border-slate-200 rounded-[2rem] p-4 md:p-8 shadow-sm hover:shadow-xl transition-all duration-700 cursor-pointer group" onclick="toggleRow(this, event)">
            
            <div class="flex justify-between items-center mb-6">
                <div>
                    <span class="text-blue-600 text-xs font-bold uppercase tracking-widest bg-blue-100 px-3 py-1 rounded-full mb-2 inline-block">Kolekcja #1</span>
                    <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Kolekcja Obuwia Premium</h2>
                </div>
                <div class="text-gray-400 group-hover:text-blue-600 transition-colors">
                    <span class="text-sm font-bold hidden md:inline mr-2 expand-text">Kliknij wiersz, aby powiększyć</span>
                    <svg class="w-8 h-8 inline-block transform transition-transform duration-500 expand-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </div>
            </div>

            <div class="project-grid grid grid-cols-1 lg:grid-cols-4 gap-4 md:gap-6 h-[450px] lg:h-[320px] overflow-hidden transition-all duration-[800ms] ease-in-out">
                
                <div class="lg:col-span-1 grid grid-cols-2 grid-rows-2 gap-2 md:gap-4 h-full min-h-0">
                    <a href="/images/portfolio/pack1.webp" data-fancybox="obuwie" data-caption="Packshot Przód" class="block rounded-xl overflow-hidden shadow-sm border border-gray-100 bg-white relative">
                        <img src="/images/portfolio/pack1.webp" loading="lazy" decoding="async" class="w-full h-full object-contain p-2 md:p-4 transition-transform duration-700 hover:scale-110" alt="Shoe"/>
                        <div class="absolute bottom-2 left-2 bg-black/60 text-white text-[10px] px-2 py-1 rounded backdrop-blur-sm hidden lg:block">Baza: Packshot</div>
                    </a>
                    <a href="/images/portfolio/pack2.webp" data-fancybox="obuwie" data-caption="Packshot Tył" class="block rounded-xl overflow-hidden shadow-sm border border-gray-100 bg-white relative">
                        <img src="/images/portfolio/pack2.webp" loading="lazy" decoding="async" class="w-full h-full object-contain p-2 md:p-4 transition-transform duration-700 hover:scale-110" alt="Shoe"/>
                    </a>
                    <a href="/images/portfolio/pack3.webp" data-fancybox="obuwie" data-caption="Packshot Bok" class="block rounded-xl overflow-hidden shadow-sm border border-gray-100 bg-white relative">
                        <img src="/images/portfolio/pack3.webp" loading="lazy" decoding="async" class="w-full h-full object-contain p-2 md:p-4 transition-transform duration-700 hover:scale-110" alt="Shoe"/>
                    </a>
                    <a href="/images/portfolio/pack4.webp" data-fancybox="obuwie" data-caption="Detale" class="block rounded-xl overflow-hidden shadow-sm border border-gray-100 bg-white relative">
                        <img src="/images/portfolio/pack4.webp" loading="lazy" decoding="async" class="w-full h-full object-contain p-2 md:p-4 transition-transform duration-700 hover:scale-110" alt="Shoe"/>
                    </a>
                </div>

                <div class="lg:col-span-2 grid grid-cols-4 grid-rows-2 gap-2 md:gap-3 h-full min-h-0 relative">
                    
                    <a href="/images/portfolio/mod1.webp" data-fancybox="obuwie" class="col-span-2 row-span-2 block rounded-xl overflow-hidden shadow-md relative group/fashion">
                        <img src="/images/portfolio/mod1.webp" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 group-hover/fashion:scale-105" alt="Fashion 1"/>
                        <div class="absolute bottom-2 left-2 bg-purple-600 text-white text-[10px] font-bold px-2 py-1 rounded-md shadow-lg z-10 hidden md:block">Modelka = AI</div>
                    </a>
                    
                    <a href="/images/portfolio/mod2.webp" data-fancybox="obuwie" class="col-span-1 row-span-1 block rounded-xl overflow-hidden shadow-sm relative group/fashion">
                        <img src="/images/portfolio/mod2.webp" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 group-hover/fashion:scale-105" alt="Fashion 2"/>
                    </a>

                    <a href="/images/portfolio/mod3.webp" data-fancybox="obuwie" class="col-span-1 row-span-2 block rounded-xl overflow-hidden shadow-sm relative group/fashion">
                        <img src="/images/portfolio/mod3.webp" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 group-hover/fashion:scale-105" alt="Fashion 3"/>
                    </a>

                    <a href="/images/portfolio/mod4.webp" data-fancybox="obuwie" class="col-span-1 row-span-1 block rounded-xl overflow-hidden shadow-sm relative group/fashion">
                        <img src="/images/portfolio/mod4.webp" loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 group-hover/fashion:scale-105" alt="Fashion 4"/>
                    </a>

                </div>

                <div class="lg:col-span-1 grid grid-cols-2 lg:grid-cols-1 grid-rows-1 lg:grid-rows-2 gap-2 md:gap-4 h-full min-h-0">
                    <a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ" data-fancybox="obuwie" class="block rounded-xl overflow-hidden shadow-sm relative bg-slate-900 group/vid">
                        <img src="/images/portfolio/mod1.webp" loading="lazy" decoding="async" class="w-full h-full object-cover opacity-50 transition-transform duration-700 group-hover/vid:scale-110" alt="Video">
                        <div class="absolute inset-0 flex items-center justify-center">
                            <div class="w-10 h-10 md:w-14 md:h-14 bg-white/30 backdrop-blur-md rounded-full flex items-center justify-center group-hover/vid:bg-white/50 transition">
                                <svg class="w-5 h-5 md:w-6 md:h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                            </div>
                        </div>
                        <div class="absolute top-2 left-2 bg-red-600 text-white text-[10px] font-bold px-2 py-1 rounded hidden lg:block">Video już wkrótce</div>
                    </a>
                    
                    <a href="/images/portfolio/pack1.webp" data-fancybox="obuwie" data-caption="Obrót 360 stopni" class="block rounded-xl overflow-hidden shadow-sm relative bg-slate-100 group/360">
                        <img src="/images/portfolio/pack1.webp" loading="lazy" decoding="async" class="w-full h-full object-contain p-4 transition-transform duration-700 group-hover/360:scale-110" alt="360">
                        <div class="absolute inset-0 flex items-center justify-center bg-black/10">
                            <div class="bg-black/80 text-white px-3 py-1.5 md:px-4 md:py-2 rounded-full font-bold text-xs md:text-sm flex items-center gap-2 backdrop-blur-sm shadow-xl">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                Widok 360°
                            </div>
                        </div>
                    </a>
                </div>

            </div>
        </div>

       

    </div>


    <div id="view-dtp" class="hidden max-w-7xl mx-auto px-4 pb-24 animate-fade-in-slow">
        <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
            <a href="/images/scianka.jpeg" data-fancybox="dtp" data-caption="Projekt ścianki reklamowej" class="block rounded-3xl overflow-hidden shadow-lg border border-gray-100 hover:shadow-2xl hover:scale-[1.02] transition duration-500 break-inside-avoid relative group">
                <img src="/images/scianka.jpeg" alt="DTP" class="w-full h-auto object-cover bg-slate-100"/>
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition duration-300 flex items-center justify-center">
                    <div class="text-center text-white">
                        <svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                        <span class="font-bold block text-lg">Ścianka Targowa stoiska na między narodowych targach MICAM we Włoszech na zlecenie Bioeco by Arka 1927</span>
                        <span class="text-sm">Powiększ projekt</span>
                    </div>
                </div>
            </a>
             <a href="/images/portfolio/artykol.jpg" data-fancybox="dtp" data-caption="Projekt ścianki reklamowej" class="block rounded-3xl overflow-hidden shadow-lg border border-gray-100 hover:shadow-2xl hover:scale-[1.02] transition duration-500 break-inside-avoid relative group">
                <img src="/images/portfolio/artykol.jpg" alt="DTP" class="w-full h-auto object-cover bg-slate-100"/>
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition duration-300 flex items-center justify-center">
                    <div class="text-center text-white">
                        <svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                        <span class="font-bold block text-lg">Projekt strony reklamowej w znanym Polskim czasopiśmie na zlecenie Bioeco by Arka 1927</span>
                        <span class="text-sm">Powiększ projekt</span>
                    </div>
                </div>
            </a>
            <a href="/images/portfolio/fotoshoe.jpg" data-fancybox="dtp" data-caption="Projekt ścianki reklamowej" class="block rounded-3xl overflow-hidden shadow-lg border border-gray-100 hover:shadow-2xl hover:scale-[1.02] transition duration-500 break-inside-avoid relative group">
                <img src="/images/portfolio/fotoshoe.jpg" alt="DTP" class="w-full h-auto object-cover bg-slate-100"/>
                <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition duration-300 flex items-center justify-center">
                    <div class="text-center text-white">
                        <svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                        <span class="font-bold block text-lg">Projekt okładki dla włoskiego magazynu na zlecenie Bioeco by Arka 1927</span>
                        <span class="text-sm">Powiększ projekt</span>
                    </div>
                </div>
            </a>
        </div>
        
    </div>

    <div class="max-w-[1400px] mx-auto px-4 pb-24 mt-12">
        <div class="relative bg-slate-900 rounded-[2rem] md:rounded-[3rem] p-10 md:p-20 overflow-hidden shadow-2xl text-center group">
            
            <div class="absolute top-0 right-0 w-96 h-96 bg-blue-600/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 transition-transform duration-1000 group-hover:scale-110"></div>
            <div class="absolute bottom-0 left-0 w-96 h-96 bg-purple-600/20 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2 transition-transform duration-1000 group-hover:scale-110"></div>
            
            <div class="relative z-10">
                <span class="text-blue-400 font-bold tracking-widest text-xs uppercase mb-4 block">Kolejny krok</span>
                <h2 class="text-3xl md:text-5xl font-black text-white mb-6 tracking-tight">
                    Spodobały Ci się nasze realizacje?
                </h2>
                <p class="text-gray-400 text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
                    Niezależnie od tego, czy potrzebujesz idealnie czystych packshotów, czy kompletnej rewolucji wizualnej z użyciem AI. Zbudujmy to razem.
                </p>
                
                <div class="flex flex-col sm:flex-row justify-center gap-4">
                    <a href="/kontakt" class="px-8 py-4 bg-white text-slate-900 font-bold rounded-full hover:scale-105 hover:shadow-[0_0_30px_rgba(255,255,255,0.3)] transition-all duration-300">
                        Porozmawiajmy o projekcie
                    </a>
                    <a href="oferta#pakiety" class="px-8 py-4 border border-slate-700 text-white font-bold rounded-full hover:bg-slate-800 hover:border-slate-500 transition-all duration-300">
                        Zobacz cennik i pakiety
                    </a>
                </div>
                
                <p class="text-slate-500 text-xs mt-8 font-medium">
                    <span class="text-green-400 inline-block mr-1">●</span> Szybka wycena w 24h. Bez ukrytych kosztów.
                </p>
            </div>
            
        </div>
    </div>

</MainLayout>

<style is:global>
    .animate-fade-in-slow {
        animation: fadeInSlow 0.6s ease-out forwards;
    }
    @keyframes fadeInSlow {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        // Inicjalizacja profesjonalnej galerii Fancybox (obsługa Zoomu i nawigacji)
        Fancybox.bind('[data-fancybox]', {
            Thumbs: { autoStart: true },
            Toolbar: {
                display: {
                    left: ["infobar"],
                    middle: ["zoomIn", "zoomOut", "toggle1to1", "rotateCCW", "rotateCW"],
                    right: ["slideshow", "thumbs", "close"],
                },
            }
        });

        // Obsługa płynnego rozsuwania wierszy
        window.toggleRow = function(rowElement, event) {
            // Jeśli klikniesz na zdjęcie z linkiem, otworzy się Fancybox - przerywamy działanie skryptu wiersza
            if(event.target.closest('a[data-fancybox]')) return;

            const grid = rowElement.querySelector('.project-grid');
            const icon = rowElement.querySelector('.expand-icon');
            const text = rowElement.querySelector('.expand-text');
            const isExpanded = rowElement.classList.contains('is-expanded');

            // Zwiń pozostałe otwarte wiersze (estetyka)
            document.querySelectorAll('.project-row.is-expanded').forEach(row => {
                if (row !== rowElement) {
                    row.classList.remove('is-expanded');
                    row.querySelector('.project-grid').classList.remove('h-[1100px]', 'lg:h-[700px]');
                    row.querySelector('.project-grid').classList.add('h-[450px]', 'lg:h-[320px]');
                    row.querySelector('.expand-icon').classList.remove('rotate-180');
                    if(row.querySelector('.expand-text')) row.querySelector('.expand-text').innerText = 'Kliknij wiersz, aby powiększyć';
                }
            });

            // Rozwiń/Zwiń ten, który kliknąłeś
            if(!isExpanded) {
                rowElement.classList.add('is-expanded');
                grid.classList.remove('h-[450px]', 'lg:h-[320px]');
                // Magia: rozciągamy na 700px, przez co przycięte wcześniej zdjęcia modowe pokazują cały detal!
                grid.classList.add('h-[1100px]', 'lg:h-[700px]'); 
                icon.classList.add('rotate-180');
                if(text) text.innerText = 'Zwiń projekt';
            } else {
                rowElement.classList.remove('is-expanded');
                grid.classList.add('h-[450px]', 'lg:h-[320px]');
                grid.classList.remove('h-[1100px]', 'lg:h-[700px]');
                icon.classList.remove('rotate-180');
                if(text) text.innerText = 'Kliknij wiersz, aby powiększyć';
            }
        };

        // Przełączanie widoków (Ecommerce vs DTP)
        const btnEco = document.getElementById('btn-ecommerce');
        const btnDtp = document.getElementById('btn-dtp');
        const viewEco = document.getElementById('view-ecommerce');
        const viewDtp = document.getElementById('view-dtp');

        btnEco.addEventListener('click', () => {
            btnEco.classList.add('bg-white', 'text-slate-900', 'shadow-lg');
            btnEco.classList.remove('text-gray-500', 'hover:text-slate-900');
            btnDtp.classList.remove('bg-white', 'text-slate-900', 'shadow-lg');
            btnDtp.classList.add('text-gray-500', 'hover:text-slate-900');
            viewEco.classList.remove('hidden');
            viewDtp.classList.add('hidden');
        });

        btnDtp.addEventListener('click', () => {
            btnDtp.classList.add('bg-white', 'text-slate-900', 'shadow-lg');
            btnDtp.classList.remove('text-gray-500', 'hover:text-slate-900');
            btnEco.classList.remove('bg-white', 'text-slate-900', 'shadow-lg');
            btnEco.classList.add('text-gray-500', 'hover:text-slate-900');
            viewEco.classList.add('hidden');
            viewDtp.classList.remove('hidden');
        });
    });
</script>