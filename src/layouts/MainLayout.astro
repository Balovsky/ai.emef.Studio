    <script>
        import Lenis from '@studio-freight/lenis'
        import AOS from 'aos';

        window.addEventListener('load', () => {
        const preloader = document.getElementById('preloader');
        
        // Czekamy 3500ms (3.5 sekundy), żeby animacja "K&M Studio" wybrzmiała
        setTimeout(() => {
            if (preloader) {
                preloader.style.opacity = '0';
                setTimeout(() => {
                    preloader.style.display = 'none';
                    document.body.classList.remove('overflow-hidden');
                }, 700);
            }
        }, 3500); 
    });

        // Inicjalizacja Lenis i AOS (to pewnie masz)
        const lenis = new Lenis({ duration: 1.2, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), orientation: 'vertical', smoothWheel: true })
        function raf(time) { lenis.raf(time); requestAnimationFrame(raf) }
        requestAnimationFrame(raf)
        AOS.init({ duration: 800, offset: 100, once: true, easing: 'ease-out-cubic' });

        // --- TU JEST KOD KTÓREGO BRAKUJE ---
        
        // 1. Znajdź przyciski
        const menuBtn = document.getElementById('menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileLinks = document.querySelectorAll('.mobile-link');
        let isMenuOpen = false;
        

        document.addEventListener('DOMContentLoaded', () => {
            const popup = document.getElementById('exit-popup');
            const popupContent = document.getElementById('exit-popup-content');
            const closeBtn = document.getElementById('exit-popup-close');
            const dismissBtn = document.getElementById('exit-popup-dismiss');
            const ctaBtn = document.getElementById('exit-popup-cta');
            const backdrop = document.getElementById('exit-popup-backdrop');

            // Sprawdź czy użytkownik już widział popup w ciągu ostatnich 24h
            const now = new Date().getTime();
            const lastSeen = localStorage.getItem('exitPopupSeen');
            const oneDay = 24 * 60 * 60 * 1000;

            // Jeśli widział dawno temu (lub wcale), pozwól pokazać
            let canShow = !lastSeen || (now - parseInt(lastSeen) > oneDay);

            function showPopup() {
                if (!canShow || !popup || !popupContent) return;
                
                popup.classList.remove('hidden');
                // Małe opóźnienie dla animacji wejścia
                setTimeout(() => {
                    popup.classList.remove('opacity-0');
                    popupContent.classList.remove('scale-90');
                    popupContent.classList.add('scale-100');
                }, 10);

                canShow = false; // Żeby nie wyskoczył drugi raz w tej sesji
                localStorage.setItem('exitPopupSeen', now.toString()); // Zapamiętaj czas
            }

            function hidePopup() {
                if(!popup || !popupContent) return;
                popup.classList.add('opacity-0');
                popupContent.classList.remove('scale-100');
                popupContent.classList.add('scale-90');
                setTimeout(() => {
                    popup.classList.add('hidden');
                }, 500);
            }

            // 1. TRIGGER DESKTOP: Wyjazd myszką poza górną krawędź
            document.addEventListener('mouseleave', (e) => {
                if (e.clientY <= 0) {
                    showPopup();
                }
            });

            // 2. TRIGGER MOBILE: Po 20 sekundach (bo nie ma myszki)
            // Lub po przewinięciu 80% strony (opcjonalnie)
            setTimeout(() => {
                if (window.innerWidth < 1024) { // Tylko na mniejszych ekranach
                    showPopup();
                }
            }, 20000); // 20 sekund

            // Obsługa zamykania
            closeBtn?.addEventListener('click', hidePopup);
            dismissBtn?.addEventListener('click', hidePopup);
            backdrop?.addEventListener('click', hidePopup);
            ctaBtn?.addEventListener('click', hidePopup); // Po kliknięciu w ofertę też zamknij
        });

        // 2. Funkcja przełączania
        if (menuBtn && mobileMenu) { // Sprawdzamy czy elementy istnieją, żeby nie było błędów
            menuBtn.addEventListener('click', () => {
                isMenuOpen = !isMenuOpen;
                if (isMenuOpen) {
                    mobileMenu.classList.remove('hidden');
                    setTimeout(() => mobileMenu.classList.remove('opacity-0'), 10);
                    menuBtn.innerText = '✕'; // Zmiana ikony na X
                } else {
                    mobileMenu.classList.add('opacity-0');
                    setTimeout(() => mobileMenu.classList.add('hidden'), 300);
                    menuBtn.innerText = '☰'; // Zmiana ikony na Hamburger
                }
            });
        }

        // 3. Zamykanie po kliknięciu w link
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                isMenuOpen = false;
                mobileMenu.classList.add('opacity-0');
                setTimeout(() => mobileMenu.classList.add('hidden'), 300);
                if(menuBtn) menuBtn.innerText = '☰';
            });
        });

        const toTopBtn = document.getElementById('to-top-btn');

        if (toTopBtn) {
            // A. Pokazywanie/Ukrywanie przycisku przy scrollowaniu
            window.addEventListener('scroll', () => {
                // Jeśli przewinięto więcej niż 500px w dół
                if (window.scrollY > 500) {
                    toTopBtn.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
                } else {
                    // Jesteśmy na górze - ukryj
                    toTopBtn.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
                }
            });

            // B. Kliknięcie - powrót na górę z użyciem Lenis (płynnie)
            toTopBtn.addEventListener('click', () => {
                lenis.scrollTo(0); 
            });
        }

        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault(); // Zatrzymaj brzydki "skok" przeglądarki
                
                const targetId = this.getAttribute('href');
                
                // Jeśli link to tylko "#", nic nie rób (np. puste linki)
                if (targetId === '#') return;

                const targetElement = document.querySelector(targetId);

                if (targetElement) {
                    // Używamy Lenis do przewinięcia
                    lenis.scrollTo(targetId, {
                        offset: -80, // WAŻNE: Zatrzymuje się 80px wcześniej (miejsce na Twój pasek menu)
                        duration: 1.2, // Czas trwania (możesz zwiększyć, np. do 2.0 dla bardzo wolnego efektu)
                        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // Ta sama funkcja co w głównym Lenis
                    });

                    // DODATEK: Jeśli kliknięto w menu mobilnym -> zamknij je automatycznie
                    if (mobileMenu && !mobileMenu.classList.contains('hidden')) {
                        isMenuOpen = false;
                        mobileMenu.classList.add('opacity-0');
                        setTimeout(() => mobileMenu.classList.add('hidden'), 300);
                        if(menuBtn) menuBtn.innerText = '☰';
                    }
                }
            });
        });
    </script>
</body>
</html> -->


