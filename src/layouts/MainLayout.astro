            stroke-linejoin: round;
            letter-spacing: -25px;
        }

        .title-main {
            font-size: 120px;
            stroke: white;
        }

        .title-sub {
            font-size: 70px;
            stroke: url(#textGradient);
            letter-spacing: 10px; /* Nieco mniejszy spacing */
        }

        /* Klasa uruchamiająca animację */
        .stroke-anim {
            stroke-dasharray: 1000; /* Długość kreski */
            stroke-dashoffset: 1000; /* Przesunięcie (ukrycie) */
            animation: drawStroke 2.5s ease-out forwards, fillText 1s 2s forwards;
        }

        /* 1. Rysowanie linii */
        @keyframes drawStroke {
            to {
                stroke-dashoffset: 0;
            }
        }

        /* 2. Wypełnianie kolorem */
        @keyframes fillText {
            to {
                fill-opacity: 1;
                stroke: transparent;
            }
        }
        
        /* Specjalne wypełnienie dla K&M (Białe) */
        .title-main {
            fill: white;
            fill-opacity: 0;
        }

        /* Specjalne wypełnienie dla STUDIO (Gradient) */
        .title-sub {
            fill: url(#textGradient);
            fill-opacity: 0;
            animation-delay: 0.5s; /* STUDIO startuje później */
        }
        
        /* Responsywność dla mobile (zmniejszamy tekst) */
        @media (max-width: 768px) {
            .title-main { font-size: 80px; }
