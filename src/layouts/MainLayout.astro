import 'aos/dist/aos.css';

interface Props {
  title?: string;
  description?: string; // Dodajemy opcjonalny opis
}

const { 
  title = "KM-Studio | Fotografia Produktowa & AI - Kalwaria Zebrzydowska / Wadowice", 
  description = "Profesjonalna fotografia produktowa, packshoty i kampanie AI. Studio fotograficzne w Kalwarii Zebrzydowskiej (okolice Wadowic i Krakowa). Obsługa E-commerce w całej Polsce."
} = Astro.props;

const currentYear = new Date().getFullYear();
